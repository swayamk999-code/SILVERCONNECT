// src/components/ui/Card.tsx
import React from 'react'
import { cn } from '@/lib/utils'

interface CardProps {
  children: React.ReactNode
  className?: string
  variant?: 'default' | 'premium' | 'dark' | 'bordered' | 'glass'
  hover?: boolean
  padding?: 'none' | 'sm' | 'md' | 'lg'
}

export default function Card({
  children,
  className,
  variant = 'default',
  hover = true,
  padding = 'lg',
}: CardProps) {
  const variants = {
    default: 'bg-white border border-silver-100 shadow-sm',
    premium: 'bg-white border border-silver-100 shadow-premium',
    dark: 'bg-primary-950 border border-white/10 text-white',
    bordered: 'bg-white border-2 border-silver-200',
    glass: 'glass',
  }

  const paddings = {
    none: '',
    sm: 'p-4',
    md: 'p-6',
    lg: 'p-8',
  }

  return (
    <div
      className={cn(
        'rounded-2xl',
        variants[variant],
        paddings[padding],
        hover &&
          'transition-all duration-500 hover:shadow-premium-lg hover:-translate-y-1',
        className
      )}
    >
      {children}
    </div>
  )
}
