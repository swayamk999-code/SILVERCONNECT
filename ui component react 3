// src/components/ui/Input.tsx
'use client'

import React, { useState } from 'react'
import { cn } from '@/lib/utils'

interface InputProps extends React.InputHTMLAttributes<HTMLInputElement> {
  label?: string
  error?: string
  icon?: React.ReactNode
  helperText?: string
}

const Input = React.forwardRef<HTMLInputElement, InputProps>(
  ({ label, error, icon, helperText, className, ...props }, ref) => {
    const [focused, setFocused] = useState(false)

    return (
      <div className="space-y-1.5">
        {label && (
          <label className="block text-sm font-medium text-silver-700">
            {label}
          </label>
        )}
        <div className="relative">
          {icon && (
            <div className="absolute left-4 top-1/2 -translate-y-1/2 text-silver-400">
              {icon}
            </div>
          )}
          <input
            ref={ref}
            className={cn(
              'w-full px-4 py-3.5 rounded-xl border bg-white text-silver-900',
              'placeholder:text-silver-400',
              'transition-all duration-300',
              'focus:outline-none focus:ring-2 focus:ring-primary-500/20 focus:border-primary-500',
              'hover:border-silver-300',
              error
                ? 'border-red-300 focus:ring-red-500/20 focus:border-red-500'
                : 'border-silver-200',
              icon && 'pl-12',
              focused && !error && 'border-primary-500 ring-2 ring-primary-500/20',
              className
            )}
            onFocus={(e) => {
              setFocused(true)
              props.onFocus?.(e)
            }}
            onBlur={(e) => {
              setFocused(false)
              props.onBlur?.(e)
            }}
            {...props}
          />
        </div>
        {error && <p className="text-sm text-red-600">{error}</p>}
        {helperText && !error && (
          <p className="text-sm text-silver-500">{helperText}</p>
        )}
      </div>
    )
  }
)

Input.displayName = 'Input'
export default Input
