// src/components/shared/GradientText.tsx
import { cn } from '@/lib/utils'

interface GradientTextProps {
  children: React.ReactNode
  className?: string
  variant?: 'blue' | 'gold' | 'emerald'
}

export default function GradientText({
  children,
  className,
  variant = 'blue',
}: GradientTextProps) {
  const gradients = {
    blue: 'from-primary-600 via-primary-500 to-primary-700',
    gold: 'from-accent-gold via-yellow-500 to-amber-600',
    emerald: 'from-emerald-500 via-teal-500 to-cyan-500',
  }

  return (
    <span
      className={cn(
        'bg-clip-text text-transparent bg-gradient-to-r',
        gradients[variant],
        className
      )}
    >
      {children}
    </span>
  )
}
